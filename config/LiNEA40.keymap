#define ZMK_POINTING_DEFAULT_SCRL_VAL 150

#include <dt-bindings/zmk/input_transform.h>
#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define MOUSE 1
#define MARK 2
#define CURSOR 3
#define FUNCTION 4
#define SCROLL 5
#define WIRELESS 6

//mouse cursol

&mmv {
    delay-ms = <20>;
    trigger-period-ms = <5>;
    time-to-max-speed-ms = <100>;
    acceleration-exponent = <2>;
};

//mouse scroll

&msc {
    delay-ms = <3>;
    trigger-period-ms = <3>;
    time-to-max-speed-ms = <100>;
    acceleration-exponent = <0>;
};

/ {
    input_processors {
        zip_wheel_scaler: zip_wheel_scaler {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <2>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_WHEEL>;
            track-remainders;
        };
    };
};

&msc_input_listener {
    speed_up {
        layers = <FUNCTION>;
        input-processors = <&zip_wheel_scaler 3 1>; //スクロールを3倍速にする
    };
};

&trackball_listener {
    scroller {
        layers = <SCROLL>;
        input-processors =
            <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>,
            //スクロール方向を逆転,,,,,,,,,,,,,,
            <&zip_xy_to_scroll_mapper>;
    };
};

/ {
    combos {
        compatible = "zmk,combos";

        ZenkakuHankaku {
            bindings = <&kp GRAVE>;
            key-positions = <11 12>;
        };

        DeleteKey {
            bindings = <&kp DEL>;
            key-positions = <7 8>;
        };

        InsertKey {
            bindings = <&kp INS>;
            key-positions = <6 7>;
        };

        CenterClick {
            bindings = <&mkp MB3>;
            key-positions = <17 16>;
        };

        PrevClick {
            bindings = <&mkp MB4>;
            key-positions = <27 28>;
        };

        ClickNext {
            bindings = <&mkp MB5>;
            key-positions = <26 27>;
        };

        inner_paren {
            bindings = <&inner_paren>;
            key-positions = <15 16>;
        };

        inner_brace {
            bindings = <&inner_brace>;
            key-positions = <17 18>;
        };

        inner_bracket {
            bindings = <&inner_bracket>;
            key-positions = <25 26>;
        };

        change_source {
            bindings = <&kp LG(SPACE)>;
            key-positions = <10 34>;
        };

        tilde {
            bindings = <&kp TILDE>;
            key-positions = <12 13>;
        };

        backspace {
            bindings = <&kp MINUS>;
            key-positions = <8 9>;
        };

        under_score {
            bindings = <&kp UNDERSCORE>;
            key-positions = <18 19>;
        };
    };

    behaviors {
        re_kp: sensor_rotate_kp {
            compatible = "zmk,behavior-sensor-rotate-var";
            #sensor-binding-cells = <2>;
            bindings = <&kp>, <&kp>;
        };

        mouse_scrl: mouse_wheel_scrl {
            compatible = "zmk,behavior-sensor-rotate-var";
            #sensor-binding-cells = <2>;
            bindings = <&msc>, <&msc>;

            tap-ms = <20>;
        };
    };

    macros {
        inner_paren: m1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_PARENTHESIS &kp RIGHT_PARENTHESIS &kp LEFT_ARROW>;
            label = "M1";
        };

        inner_brace: inner_brace {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_BRACE &kp RIGHT_BRACE &kp LEFT_ARROW>;
            label = "INNER_BRACE";
        };

        inner_bracket: inner_bracket {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_BRACKET &kp RIGHT_BRACKET &kp LEFT_ARROW>;
            label = "INNER_BRACKET";
        };

        inner_angle: inner_angle {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LESS_THAN &kp GREATER_THAN &kp LEFT_ARROW>;
            label = "INNER_ANGLE";
        };

        inner_quote: inner_quote {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp DOUBLE_QUOTES &kp DOUBLE_QUOTES &kp LEFT_ARROW>;
            label = "INNER_QUOTE";
        };

        inner_single: inner_single {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SINGLE_QUOTE &kp SINGLE_QUOTE &kp LEFT_ARROW>;
            label = "INNER_SINGLE";
        };

        inner_back: inner_back {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp GRAVE &kp GRAVE &kp LEFT_ARROW>;
            label = "INNER_BACK";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp Q         &kp W         &kp E             &kp R    &kp T                                     &kp Y        &kp U  &kp I         &kp O          &kp P
&kp A         &kp S         &kp D             &kp F    &kp G                                     &kp H        &kp J  &kp K         &kp L          &kp SEMICOLON
&kp Z         &kp X         &kp C             &kp V    &kp B                                     &kp N        &kp M  &kp COMMA     &kp DOT        &kp SLASH
&kp LEFT_GUI  &kp LEFT_ALT  &kp LEFT_CONTROL  &kp INS  &kp LEFT_SHIFT  &lt 2 SPACE    &lt 4 TAB  &lt 3 ENTER         &lt 5 ESCAPE  &kp BACKSLASH  &kp SINGLE_QUOTE
            >;

            sensor-bindings = <&mouse_scrl SCRL_DOWN SCRL_UP>;
        };

        MOUSE {
            bindings = <
&trans  &trans  &trans  &trans  &trans                    &trans  &trans    &trans    &trans  &trans
&trans  &trans  &trans  &trans  &trans                    &trans  &mkp MB1  &mkp MB2  &trans  &trans
&trans  &trans  &trans  &trans  &trans                    &trans  &trans    &trans    &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans            &trans    &trans  &trans
            >;
        };

        MARK {
            bindings = <
&kp EXCLAMATION  &kp AT  &kp HASH  &kp DOLLAR  &kp PERCENT                    &kp CARET             &kp AMPERSAND          &kp ASTERISK    &kp MINUS  &kp EQUAL
&trans           &trans  &trans    &kp GRAVE   &kp TILDE                      &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp LEFT_BRACE  &kp RBRC   &kp BACKSPACE
&kp LEFT_SHIFT   &trans  &trans    &trans      &trans                         &kp LEFT_BRACKET      &kp RIGHT_BRACKET      &kp LESS_THAN   &kp GT     &trans
&trans           &trans  &trans    &trans      &trans       &trans    &trans  &kp ENTER                                    &trans          &trans     &trans
            >;

            sensor-bindings = <&re_kp C_VOLUME_DOWN C_VOLUME_UP>;
        };

        Number {
            bindings = <
&kp NUMBER_1    &kp NUMBER_2  &kp NUMBER_3  &kp NUMBER_4  &kp N5                    &kp NUMBER_6  &kp N7  &kp N8  &kp N9         &kp N0
&kp LEFT_GUI    &trans        &trans        &trans        &trans                    &trans        &trans  &trans  &kp LG(GRAVE)  &kp BACKSPACE
&kp LEFT_SHIFT  &trans        &trans        &trans        &trans                    &trans        &trans  &trans  &trans         &trans
&trans          &trans        &trans        &trans        &trans  &trans    &trans  &trans                &trans  &trans         &trans
            >;

            sensor-bindings = <&inc_dec_kp C_VOLUME_UP C_VOLUME_DOWN>;
        };

        Function {
            bindings = <
&kp F1      &kp F2  &kp F3  &kp F4   &kp F5                                        &kp KP_MULTIPLY  &kp NUMBER_7  &kp NUMBER_8  &kp NUMBER_9  &kp KP_PLUS
&kp F6      &kp F7  &kp F8  &kp F9   &kp F10                                       &kp KP_SLASH     &kp NUMBER_4  &kp NUMBER_5  &kp NUMBER_6  &kp KP_MINUS
&trans      &trans  &trans  &kp F11  &kp F12                                       &kp UNDER        &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &kp ENTER
&kp C_MUTE  &trans  &trans  &trans   &kp C_VOLUME_DOWN  &kp C_VOLUME_UP    &trans  &kp NUMBER_0                   &kp NUMBER_0  &kp DOT       &kp QUESTION
            >;

            sensor-bindings = <&inc_dec_kp DOWN_ARROW UP_ARROW>;
        };

        WIRELESS {
            bindings = <
&bt BT_SEL 0    &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4                              &trans          &kp LC(LEFT_ARROW)  &kp LC(UP_ARROW)    &kp LC(RIGHT_ARROW)  &kp BACKSPACE
&kp LEFT_GUI    &trans        &trans        &trans        &trans                                    &trans          &trans              &kp LC(DOWN_ARROW)  &kp UP_ARROW         &kp ENTER
&kp LEFT_SHIFT  &trans        &trans        &trans        &trans                                    &trans          &trans              &kp LEFT_ARROW      &kp DOWN_ARROW       &kp RIGHT_ARROW
&kp LCTRL       &trans        &trans        &trans        &bt BT_CLR    &bootloader    &bootloader  &studio_unlock                      &trans              &trans               &trans
            >;

            sensor-bindings = <&inc_dec_kp RIGHT_ARROW LEFT_ARROW>;
        };
    };
};
